// AI 简报内容
const AI_BRIEFS = {
  followed: '今日关注高校共发文 12 篇，热词 TOP3：科研成果、校园秋景、就业质量。华东师大《Nature》论文获高关注，值得学习其科研宣传策略。',
  ourschool: '本周南师大主号发文 5 篇，平均阅读量 1.2w，较上周上升 15%。建议增加情感类内容比例，提升分享率。',
  benchmark: '全网爆款分析：视觉流（图片叙事）占 45%，情感流（校园情怀）占 35%，干货流（实用信息）占 20%。建议多尝试视觉流策略。',
}

type Step = 'idle' | 'scoring' | 'scored' | 'generating' | 'done'

export default function Home() {
  const [accountId, setAccountId] = useState('njnu-main')
  const [topicIdea, setTopicIdea] = useState('')
  const [step, setStep] = useState<Step>('idle')
  const [scoreData, setScoreData] = useState<Record<string, unknown> | null>(null)
  const [titles, setTitles] = useState<unknown[]>([])
  const [error, setError] = useState('')

  const [showHot, setShowHot] = useState(true)
  const [showCal, setShowCal] = useState(false)

  // 三维对标状态
  const [activeTab, setActiveTab] = useState<'followed' | 'ourschool' | 'benchmark'>('followed')
  const [selectedSchool, setSelectedSchool] = useState<string | null>('ecnu')

  const banner = ACCOUNT_BANNERS[accountId]
  const showSidebar = step === 'scored' || step === 'generating' || step === 'done'

  // 获取当前显示的文章列表
  const getCurrentArticles = (): ArticleCard[] => {
    if (activeTab === 'followed') {
      return MOCK_ARTICLES[`followed-${selectedSchool}`] || []
    } else if (activeTab === 'ourschool') {
      return MOCK_ARTICLES[`ourschool-${selectedSchool}`] || []
    } else {
      return MOCK_ARTICLES['benchmark-all'] || []
    }
  }

  const handleAccountChange = (id: string) => {
    setAccountId(id)
    setStep('idle')
    setScoreData(null)
    setTitles([])
    setError('')
  }

  const handleScore = async () => {
    if (!topicIdea.trim()) return
    setStep('scoring')
    setError('')
    setScoreData(null)
    setTitles([])
    try {
      const res = await fetch('/api/score', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ accountId, idea: topicIdea })
      })
      const data = await res.json()
      if (data.error) throw new Error(data.error)
      setScoreData(data)
      setStep('scored')
    } catch (e: unknown) {
      setError(e instanceof Error ? e.message : '请求失败，请重试')
      setStep('idle')
    }
  }

  const handleGenerateTitles = async () => {
    setStep('generating')
    try {
      const res = await fetch('/api/titles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ accountId, topic: topicIdea })
      })
      const data = await res.json()
      if (data.error) throw new Error(data.error)
      setTitles(Array.isArray(data) ? data : [])
      setStep('done')
    } catch (e: unknown) {
      setError(e instanceof Error ? e.message : '请求失败，请重试')
      setStep('scored')
    }
  }

  const handleSelectTopic = (idea: string) => {
    setTopicIdea(idea)
    setStep('idle')
    setScoreData(null)
    setTitles([])
    setTimeout(() => {
      document.getElementById('workspace')?.scrollIntoView({ behavior: 'smooth' })
    }, 100)
  }

  return (
    <div className="min-h-screen">
      {/* 顶部页面标题栏 */}
      <header className="bg-white border-b sticky top-0 z-30" style={{ borderColor: 'var(--border)', boxShadow: 'var(--shadow-md)' }}>
        <div className="max-w-7xl mx-auto px-8 h-16 flex items-center">
          <h1 className="text-lg font-bold" style={{ color: 'var(--foreground)' }}>
            🏠 首页
          </h1>
        </div>
      </header>

      <div className="max-w-7xl mx-auto px-8 py-8">
        <div className={`flex gap-6 items-start ${showSidebar ? '' : 'justify-center'}`}>

          {/* 主内容区 */}
          <main className={`space-y-6 min-w-0 flex-1`}>

            {/* 三维对标体系 */}
            <section>
              <h2 className="text-xs font-semibold uppercase tracking-wider mb-4" style={{ color: 'var(--foreground-tertiary)' }}>
                情报对标与数据复盘
              </h2>

              <div className="bg-white rounded-lg border p-6" style={{ borderColor: 'var(--border)', boxShadow: 'var(--shadow-sm)' }}>
                {/* Tab 切换 */}
                <TabSwitch
                  tabs={BENCHMARK_TABS}
                  activeTab={activeTab}
                  onChange={(id) => {
                    setActiveTab(id as typeof activeTab)
                    // 切换 tab 时重置选中的学校
                    if (id === 'followed') {
                      setSelectedSchool('ecnu')
                    } else if (id === 'ourschool') {
                      setSelectedSchool('njnu-main')
                    } else {
                      setSelectedSchool(null)
                    }
                  }}
                />

                <div className="mt-6">
                  {/* AI 简报 */}
                  <AIBrief
                    content={
                      activeTab === 'followed'
                        ? AI_BRIEFS.followed
                        : activeTab === 'ourschool'
                        ? AI_BRIEFS.ourschool
                        : AI_BRIEFS.benchmark
                    }
                  />

                  {/* 头像滚动条（关注高校和本校复盘维度显示） */}
                  {activeTab === 'followed' && (
                    <SchoolAvatarScroll
                      schools={FOLLOWED_SCHOOLS}
                      selectedId={selectedSchool}
                      onSelect={setSelectedSchool}
                    />
                  )}
                  {activeTab === 'ourschool' && (
                    <SchoolAvatarScroll
                      schools={OUR_SCHOOLS}
                      selectedId={selectedSchool}
                      onSelect={setSelectedSchool}
                    />
                  )}

                  {/* 瀑布流卡片 */}
                  <ArticleWaterfall articles={getCurrentArticles()} />
                </div>
              </div>
            </section>

            <div className="h-12" />
          </main>

          {/* 右侧侧边栏：大纲 + 意向图 + 标题预览 */}
          {showSidebar && (
            <aside className="w-64 flex-shrink-0 sticky top-20">
              <div className="text-xs font-semibold uppercase tracking-wider mb-4" style={{ color: 'var(--foreground-tertiary)' }}>
                文案预览
              </div>
              <OutlineSidebar
                topic={topicIdea}
                // eslint-disable-next-line @typescript-eslint/no-explicit-any
                titles={titles as any[]}
                generating={step === 'generating'}
              />
            </aside>
          )}

        </div>
      </div>
    </div>
  )
}
