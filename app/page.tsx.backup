  'njnu-main': { label: '南京师范大学 · 官方主号', hint: '受众：在校生 + 校友 · KPI：阅读量 + 分享率', color: 'bg-green-600' },
  'njnu-admissions': { label: '南师招生 · 招生专号', hint: '受众：高中生 + 家长 · KPI：招生咨询转化', color: 'bg-emerald-500' },
  'ecnu-main': { label: '华东师范大学 · 竞品参考', hint: '查看竞品数据洞察和选题对比', color: 'bg-blue-600' },
  'ecnu-admissions': { label: '华东师大本科招生 · 竞品参考', hint: '查看竞品招生号数据和内容策略', color: 'bg-blue-500' },
}

// 三维对标的 Tab 数据
const BENCHMARK_TABS = [
  { id: 'followed', label: '关注高校' },
  { id: 'ourschool', label: '本校复盘' },
  { id: 'benchmark', label: '标杆案例' },
]

